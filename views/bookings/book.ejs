<% layout("/layouts/boilerplate") %>

<style>
  .booking-wrapper {
    max-width: 520px;
    margin: 50px auto;
    padding: 36px;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    background: #fff;
  }
  .booking-wrapper h2 { font-weight: 700; color: #222; margin-bottom: 4px; }
  .booking-wrapper .listing-meta { color: #888; font-size: 14px; margin-bottom: 24px; }
  .booking-wrapper label { font-weight: 600; color: #444; font-size: 14px; }
  .booking-wrapper .form-control {
    border-radius: 8px; border: 1.5px solid #ddd; padding: 10px 14px;
    font-size: 15px; transition: border-color 0.2s;
  }
  .booking-wrapper .form-control:focus { border-color: #fe424d; box-shadow: 0 0 0 3px rgba(254,66,77,0.12); }
  .price-box {
    background: #fff5f5; border: 1.5px solid #fe424d; border-radius: 10px;
    padding: 18px 20px; margin: 20px 0;
  }
  .price-box .per-night { color: #888; font-size: 13px; }
  .price-box .total-price { font-size: 26px; font-weight: 700; color: #fe424d; }
  .btn-pay {
    background: #fe424d; color: #fff; border: none; width: 100%;
    padding: 13px; border-radius: 10px; font-size: 17px; font-weight: 700;
    cursor: pointer; transition: background 0.2s; margin-top: 6px;
  }
  .btn-pay:hover { background: #d93540; }
  .btn-pay:disabled { background: #ccc; cursor: not-allowed; }
  .listing-img {
    width: 100%; height: 180px; object-fit: cover;
    border-radius: 12px; margin-bottom: 20px;
  }
</style>

<div class="booking-wrapper">
  <img src="<%= listing.image.url %>" alt="listing image" class="listing-img">
  <h2>Book Your Stay</h2>
  <p class="listing-meta">📍 <%= listing.title %> &nbsp;•&nbsp;  <%= listing.location %>, <%= listing.country %></p>

  <div class="mb-3">
    <label for="checkIn">Check-in Date</label>
    <input type="date" id="checkIn" class="form-control mt-1" min="<%= new Date().toISOString().split('T')[0] %>" required>
  </div>

  <div class="mb-3">
    <label for="days">Number of Nights</label>
    <input type="number" id="days" class="form-control mt-1" min="1" max="30" placeholder="e.g. 3" required>
  </div>

  <div class="price-box">
    <div class="per-night">₹<%= listing.price.toLocaleString("en-IN") %> × <span id="daysDisplay">0</span> night(s)</div>
    <div class="total-price">₹<span id="totalDisplay">0</span></div>
  </div>

  <button id="payBtn" class="btn-pay" disabled>Proceed to Payment </button>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const pricePerNight = <%= listing.price %>;
  const listingId     = "<%= listing._id %>";
  const checkInInput  = document.getElementById("checkIn");
  const daysInput     = document.getElementById("days");
  const daysDisplay   = document.getElementById("daysDisplay");
  const totalDisplay  = document.getElementById("totalDisplay");
  const payBtn        = document.getElementById("payBtn");

  function updatePrice() {
    const days = parseInt(daysInput.value) || 0;
    const total = days * pricePerNight;
    daysDisplay.textContent = days;
    totalDisplay.textContent = total.toLocaleString("en-IN");
    payBtn.disabled = !(days > 0 && checkInInput.value);
  }

  checkInInput.addEventListener("change", updatePrice);
  daysInput.addEventListener("input", updatePrice);

  payBtn.addEventListener("click", async () => {
    const days    = daysInput.value;
    const checkIn = checkInInput.value;

    if (!days || !checkIn) {
      alert("Please fill in all fields.");
      return;
    }

    payBtn.disabled = true;
    payBtn.textContent = "Creating order...";

    // Step 1: Create Razorpay order on backend
    const response = await fetch(`/listings/${listingId}/book/create-order`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ days, checkIn }),
    });
    const data = await response.json();

    if (!data.orderId) {
      alert("Failed to create order. Please try again.");
      payBtn.disabled = false;
      payBtn.textContent = "Proceed to Payment 💳";
      return;
    }

    // Step 2: Open Razorpay Checkout popup
    const options = {
      key: data.key,
      amount: data.amount,
      currency: data.currency,
      name: "WonderLust",
      description: "Property Booking",
      order_id: data.orderId,
      prefill: {
        name: data.userName,
        email: data.userEmail,
      },
      theme: { color: "#fe424d" },
      handler: async function (rzpResponse) {
        // Step 3: Verify payment on backend
        const verifyRes = await fetch(`/listings/${listingId}/book/verify-payment`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            razorpay_order_id:   rzpResponse.razorpay_order_id,
            razorpay_payment_id: rzpResponse.razorpay_payment_id,
            razorpay_signature:  rzpResponse.razorpay_signature,
            bookingId:           data.bookingId,
          }),
        });
        // The server will redirect to success page on verify
        if (verifyRes.redirected) {
          window.location.href = verifyRes.url;
        } else {
          const result = await verifyRes.json();
          if (result.redirect) window.location.href = result.redirect;
        }
      },
      modal: {
        ondismiss: () => {
          payBtn.disabled = false;
          payBtn.textContent = "Proceed to Payment 💳";
        }
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  });
</script>
