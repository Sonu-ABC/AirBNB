<% layout("/layouts/boilerplate") %>

<style>
  .success-wrapper {
    max-width: 560px;
    margin: 60px auto;
    text-align: center;
  }
  .success-icon {
    font-size: 72px;
    animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes popIn {
    0%   { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .success-wrapper h1 { font-weight: 800; color: #222; margin: 12px 0 6px; }
  .success-wrapper .subtitle { color: #888; margin-bottom: 32px; }
  .booking-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    padding: 28px 32px;
    text-align: left;
    margin-bottom: 24px;
  }
  .booking-card h4 { color: #fe424d; font-weight: 700; margin-bottom: 18px; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }
  .detail-row { display: flex; justify-content: space-between; padding: 9px 0; border-bottom: 1px solid #f5f5f5; font-size: 15px; }
  .detail-row:last-child { border-bottom: none; }
  .detail-row .label { color: #888; }
  .detail-row .value { font-weight: 600; color: #222; }
  .total-row .value { color: #fe424d; font-size: 20px; font-weight: 800; }
  .listing-img { width: 100%; height: 200px; object-fit: cover; border-radius: 12px; margin-bottom: 20px; }
  .btn-home {
    display: inline-block; background: #fe424d; color: #fff; text-decoration: none;
    padding: 13px 36px; border-radius: 10px; font-weight: 700; font-size: 16px;
    transition: background 0.2s;
  }
  .btn-home:hover { background: #d93540; color: #fff; }
  .payment-id { font-size: 11px; color: #ccc; margin-top: 10px; }
</style>

<div class="success-wrapper">
  <div class="success-icon">🎉</div>
  <h1>Booking Confirmed!</h1>
  <p class="subtitle">A confirmation has been sent to your email. See you there! </p>

  <div class="booking-card">
    <img src="<%= booking.listing.image.url %>" alt="listing" class="listing-img">
    <h4> Your Booking Summary</h4>

    <div class="detail-row">
      <span class="label">Property</span>
      <span class="value"><%= booking.listing.title %></span>
    </div>
    <div class="detail-row">
      <span class="label">Destination</span>
      <span class="value"><%= booking.listing.location %>, <%= booking.listing.country %></span>
    </div>
    <div class="detail-row">
      <span class="label">Check-in</span>
      <span class="value">
        <%= new Date(booking.checkIn).toLocaleDateString("en-IN", { weekday:"long", year:"numeric", month:"long", day:"numeric" }) %>
      </span>
    </div>
    <div class="detail-row">
      <span class="label">Check-out</span>
      <span class="value">
        <% 
          const checkOut = new Date(new Date(booking.checkIn).getTime() + booking.days * 24*60*60*1000);
        %>
        <%= checkOut.toLocaleDateString("en-IN", { weekday:"long", year:"numeric", month:"long", day:"numeric" }) %>
      </span>
    </div>
    <div class="detail-row">
      <span class="label">Duration</span>
      <span class="value"><%= booking.days %> Night<%= booking.days > 1 ? "s" : "" %></span>
    </div>
    <div class="detail-row total-row">
      <span class="label">Total Paid</span>
      <span class="value">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
    </div>
  </div>

  <a href="/listings" class="btn-home"> Back to Listings</a>
  <p class="payment-id">Payment ID: <%= booking.razorpayPaymentId %></p>
</div>
